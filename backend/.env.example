NODE_ENV=development
PORT=3000

# Storage: 'local' for dev, 's3' for production (CloudFront + S3)
STORAGE_MODE=local
# Override storage root path (defaults to <project>/storage)
# STORAGE_ROOT=/data/storage

# MongoDB
MONGO_URI=mongodb://localhost:27017/youstream

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# OTP
OTP_MODE=mock
OTP_MOCK_CODE=123456
OTP_EXPIRY_MINUTES=5

# AWS (required when STORAGE_MODE=s3)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_RAW_BUCKET=youstream-raw
AWS_S3_STREAMING_BUCKET=youstream-streaming
CLOUDFRONT_DOMAIN=https://dxxxxxxxxxx.cloudfront.net
